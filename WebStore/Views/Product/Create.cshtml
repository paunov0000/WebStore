@using WebStore.Web.ViewModels.Product;
@model ProductViewModel;

@{
    ViewBag.Title = "Add a Product";
}

<h2 class="text-center">@ViewBag.Title</h2>
<hr />

<div class="row">
    <form method="post">
        <div class="form-group">
            <div class="mb-3">
                <label asp-for="@Model.Name">Product Name</label>
                <input asp-for="@Model.Name" type="text" class="form-control" placeholder="Write down the name of the product">
                <span asp-validation-for="@Model.Name" class="small text-danger"></span>
            </div>
            @* <div class="mb-3">
            <label asp-for="Description">Category Description</label>
            <input asp-for="Description" type="text" class="form-control" placeholder="Put some description for your category">
            <span asp-validation-for="Description" class="small text-danger"></span>
            </div>*@
            <div class="mb-3">
                <label asp-for="SubCategoryId" class="form-label">Subcategory</label>
                <select asp-for="SubCategoryId" class="form-control">
                    @foreach (var category in Model.SubCategories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <span asp-validation-for="SubCategoryId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.Description">Description</label>
                <input asp-for="@Model.Description" type="text" class="form-control" placeholder="Put a description for your product">
                <span asp-validation-for="@Model.Description" class="small text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="@Model.ImageURL">Image URL</label>
                <input asp-for="@Model.ImageURL" type="text" class="form-control" placeholder="Put an URL for your product's image">
                <span asp-validation-for="@Model.ImageURL" class="small text-danger"></span>
            </div>
        </div>
        <input class="btn btn-primary mt-3" type="submit" value="Create" />
    </form>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}